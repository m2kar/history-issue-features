# -- 运行控制 --
timeout: 600                          # 单 issue 超时 (秒)
subagent_parallelism: 2               # 每个 issue 内 extractor 并行度

# -- 数据源 --
repos:
  verilator: "verilator/verilator"
  circt: "llvm/circt"
  iverilog: "steveicarus/iverilog"
  yosys: "YosysHQ/yosys"

# -- 爬取控制 --
crawl:
  rate_limit: 2000                    # 每小时最大请求数
  sleep_interval: 1.8                 # 每次 API 请求间隔 (秒)
  baseline_dir: "/path/to/baseline/issues"   # 基线数据目录

# -- 输出路径 --
edazz_output: /path/to/EDAzz/data/feature_sources/history_v2/merged_history_v2_features.json

# -- Provider 配置 --
providers:
  - name: "my-provider"
    concurrency: 2
    env:
      EDA_BUG_CONFIG_NAME: "my-provider"
      ANTHROPIC_AUTH_TOKEN: "sk-YOUR-API-KEY-HERE"
      ANTHROPIC_BASE_URL: "https://api.example.com/anthropic"
      ANTHROPIC_MODEL: "model-name"
      API_TIMEOUT_MS: "3000000"
      CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC: "1"
