{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Edit(.claude/hooks/validate-feature.py)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/validate-feature.py"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/notify-progress.py"
          }
        ]
      }
    ]
  },
  "env": {
    "NO_COLOR": "1"
  }
}